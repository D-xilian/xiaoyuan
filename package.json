{
  "name": "campus-activity-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test --config=tests/e2e/playwright.config.js",
    "test:ui": "playwright test --ui --config=tests/e2e/playwright.config.js",
    "test:headed": "playwright test --headed --config=tests/e2e/playwright.config.js",
    "test:auth": "playwright test auth --config=tests/e2e/playwright.config.js",
    "test:activity": "playwright test activity --config=tests/e2e/playwright.config.js",
    "test:registration": "playwright test registration --config=tests/e2e/playwright.config.js",
    "test:admin": "playwright test admin --config=tests/e2e/playwright.config.js",
    "test:debug": "playwright test --debug --config=tests/e2e/playwright.config.js",
    "test:report": "playwright show-report test-results/report",
    "bdd": "node tests/bdd/runner.js",
    "bdd:smoke": "node tests/bdd/runner.js --tags=smoke",
    "bdd:report": "node tests/bdd/runner.js --report-only"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0"
  }
}
